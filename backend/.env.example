APP_NAME=QuemJoga API
DEBUG=true

DATABASE_URL=postgresql://postgres:postgres@db:5432/quemjoga

SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
RESET_PASSWORD_EXPIRE_MINUTES=30

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Asaas (gateway de pagamento — assinatura SaaS do admin)
# Sandbox: https://api-sandbox.asaas.com/v3  |  Produção: https://api.asaas.com/v3
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
# Token arbitrário que você define e cadastra no painel da Asaas (Webhooks).
# Webhook URL de produção: https://quemjogafc.up.railway.app/api/v1/assinaturas/webhook/asaas
ASAAS_WEBHOOK_TOKEN=
ASSINATURA_VALOR=2990
ASSINATURA_TRIAL_DIAS=14

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=5242880

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
