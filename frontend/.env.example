# API Backend URL
# Local com FastAPI:
# VITE_API_URL=http://localhost:8000
#
# Railway com backend separado:
# VITE_API_URL=https://sua-api.up.railway.app
#
# MVP frontend + Supabase sem FastAPI: deixe vazio.
VITE_API_URL=

# Supabase Auth
# Use a chave pública/publishable do projeto. Nunca use a service_role no frontend.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
